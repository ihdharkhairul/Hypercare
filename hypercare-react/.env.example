# URL backend PHP REST API
# Untuk development dengan XAMPP (mode langsung):
VITE_API_URL=http://localhost/hypercare/backend/api

# Untuk development dengan Vite proxy (lebih disarankan,
# tidak perlu env ini karena proxy sudah dikonfigurasi di vite.config.js):
# VITE_API_URL=/api
